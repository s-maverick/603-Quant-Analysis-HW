data("salary")
force(salary)
View(salary)
library('alr4')
library('smss')
library('tidyverse')
summarise(filter(salary, sex = "Male"), avg())
summarise(filter(salary, sex == "Male"), avg())
summarise(filter(salary, sex == "Male"), mean())
summarise(filter(salary, sex == "Male"), Avg_Male = mean(salary))
summarise(filter(salary, sex == "Male"), Avg_Male = mean(salary))
summarise(filter(salary, sex == "Female"), Avg_Male = mean(salary))
summarise(filter(salary, sex == "Male"), Avg_Male = mean(salary))
summarise(filter(salary, sex == "Female"), Avg_Male = mean(salary))
summarise(filter(salary, sex == "Female"), Avg_Female = mean(salary))
summarise(filter(salary, sex == "Male"), Avg_Salary_Male = mean(salary))
summarise(filter(salary, sex == "Female"), Avg_Salary_Female = mean(salary))
model1 <- lm(salary ~ degree, rank, sex, year, ysdeg)
model1 <- lm(salary ~ degree + rank + sex + year + ysdeg, salary)
summary(model1)
