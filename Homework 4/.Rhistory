library('alr4')
library('smss')
data(Jacksonville)
data(recent)
house_price_model <- function(x1, x2, actual_price) {
predicted_price <- -15000 + 25000 * x1 + 15000 * x2
residual <- actual_price - predicted_price
return(predicted_price, residual)
}
house_price_model(3, 2, 160000)
q1 <- house_price_model(3, 2, 160000)
house_price_model <- function(x1, x2, actual_price) {
predicted_price <- -15000 + 25000 * x1 + 15000 * x2
residual <- actual_price - predicted_price
return(list(predicted_price, residual))
}
q1 <- house_price_model(3, 2, 160000)
q1
house_price_model <- function(x1, x2, actual_price) {
predicted_price <- -15000 + 25000 * x1 + 15000 * x2
residual <- actual_price - predicted_price
return(c(predicted_price, residual))
}
q1 <- house_price_model(3, 2, 160000)
q1
house_price_model <- function(x1, x2, actual_price) {
predicted_price <- (-15000 + 25000 * x1 + 15000 * x2)
residual <- actual_price - predicted_price
return(c(predicted_price, residual))
}
q1 <- house_price_model(3, 2, 160000)
q1
