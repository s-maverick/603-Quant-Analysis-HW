data("student.survey")
data("student.survey")
head(student.survey)
student.survey
?student.survey
View(student.survey)
# (i) y = political ideology and x = religiosity
plot(x = student.survey$re,
y = student.survey$pi,
xlab = "Religiosity",
ylab = "Political Ideology",
main = "Relationship between Political Ideology and Religiosity")
abline(lm(pi ~ re, data = student.survey), col = "red")
# (ii) y = high school GPA and x = hours of TV watching
plot(x = student.survey$tv,
y = student.survey$hi,
xlab = "Hours of TV Watching",
ylab = "High School GPA",
main = "Relationship between High School GPA and Hours of TV Watching")
abline(lm(hi ~ tv, data = student.survey), col = "blue")
boxplot(pi ~ re,
data = student.survey,
xlab = "Religiosity (Categorical)",
ylab = "Political Ideology",
main = "Political Ideology by Religiosity")
# --- (b) Conduct regression analyses ---
# (i) Regression of political ideology on religiosity
model1 <- lm(political.ideology ~ religiosity, data = student.survey)
# --- (b) Conduct regression analyses ---
# (i) Regression of political ideology on religiosity
model1 <- lm(pi ~ re, data = student.survey)
summary(model1)
# We can use ANOVA (Analysis of Variance) to see if there's a significant difference
# in the mean political ideology across the different levels of religiosity.
model1_anova <- aov(pi ~ factor(re), data = student.survey)
summary(model1_anova)
# (ii) Regression of high school GPA on hours of TV watching
model2 <- lm(GPA.HS ~ tv, data = student.survey)
# (ii) Regression of high school GPA on hours of TV watching
model2 <- lm(hi ~ tv, data = student.survey)
summary(model2)
ggplot(data = student.survey, aes(x = tv, y = hi)) +
geom_point() +
geom_smooth(method = 'lm')
?labs()
ggplot(data = student.survey, aes(x = tv, y = hi)) +
geom_point() +
geom_smooth(method = 'lm') +
labs(xlab = "Hours of TV Watching",
ylab = "High School GPA",
title = "Relationship between High School GPA and Hours of TV Watching")
ggplot(data = student.survey, aes(x = tv, y = hi)) +
geom_point() +
geom_smooth(method = 'lm') +
labs(x = "Hours of TV Watching",
y = "High School GPA",
title = "Relationship between High School GPA and Hours of TV Watching")
