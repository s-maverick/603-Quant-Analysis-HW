plot(water$Year, water$OPSLAKE, type = "l", col = "brown", lwd = 2,
main = "OPSLAKE", xlab = "Year", ylab = "Precipitation")
points(water$Year, water$OPSLAKE, pch = 19, col = "brown")
# Plot BSAAM (Runoff)
plot(water$Year, water$BSAAM, type = "l", col = "darkblue", lwd = 2,
main = "BSAAM (Runoff)", xlab = "Year", ylab = "Runoff")
points(water$Year, water$BSAAM, pch = 19, col = "darkblue")
png("scatterplot_matrix_large.png", width = 1600, height = 1600, res = 200)
