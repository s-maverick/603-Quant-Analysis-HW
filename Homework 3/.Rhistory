model_lm_categorical <- lm(as.numeric(pi) ~ factor(re), data = student.survey)
summary(model_lm_categorical)
model_lm_categorical <- lm(factor(pi) ~ factor(re), data = student.survey)
summary(model_lm_categorical)
model_lm_categorical <- lm(as.factor(pi) ~ as.factor(re), data = student.survey)
summary(model_lm_categorical)
model_lm_categorical <- lm(as.factor(pi) ~ as.factor(re), data = student.survey)
print(model_lm_categorical)
# Perform Chi-square test to see if there is an association between pi (political ideology) and re (religiosity)
table1 <- table(student.survey$pi, student.survey$re)
chisq.test(table1)
# Perform multinomial logistic regression (pi as outcome, re as explanatory variable)
library(nnet) # Load the nnet package for multinomial regression
model_pi_re <- multinom(pi ~ re, data = student.survey)
summary(model_pi_re)
# Mosaic plot to show the relationship between pi and re
library(vcd)
install.packages("vcd")
# Mosaic plot to show the relationship between pi and re
library(vcd)
mosaic(~ pi + re, data = student.survey, main = "Mosaic Plot of Political Ideology vs Religiosity")
