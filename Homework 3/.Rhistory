# Create a contingency table
contingency_table <- table(student.survey$pi, student.survey$re)
print("Contingency Table:")
print(contingency_table)
# Perform a Chi-Squared test of independence
chi2_test <- chisq.test(contingency_table)
print("\nChi-Squared Test of Independence:")
print(chi2_test)
# Perform a Chi-Squared test of independence
chi2_test <- chisq.test(contingency_table)
print("\nChi-Squared Test of Independence:")
summary(chi2_test)
# Perform a Chi-Squared test of independence
chi2_test <- chisq.test(contingency_table)
print("\nChi-Squared Test of Independence:")
print(chi2_test)
# Stacked Bar Chart
barplot(prop.table(contingency_table, margin = 2), # Proportions by religiosity
legend.text = rownames(contingency_table),
xlab = "Religiosity",
ylab = "Proportion of Political Ideology",
main = "Political Ideology Distribution by Religiosity",
col = rainbow(nrow(contingency_table)))
ggplot(student.survey, aes(x = factor(re), fill = factor(pi))) +
geom_bar(position = "fill") + # Use position = "fill" for proportions
labs(
x = "Religiosity (Categorical)",
y = "Proportion of Political Ideology",
fill = "Political Ideology",
title = "Distribution of Political Ideology by Religiosity"
) +
scale_fill_brewer(palette = "Set3") # Optional: Choose a color palette
# Alternatively, a grouped bar chart can show the counts:
ggplot(student.survey, aes(x = factor(re), fill = factor(pi))) +
geom_bar(position = "dodge") + # Use position = "dodge" for grouped bars
labs(
x = "Religiosity (Categorical)",
y = "Count",
fill = "Political Ideology",
