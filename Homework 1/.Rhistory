df <- read.csv("LungCapData.csv")
hist(df$LungCap)
df
view(df)
View(df)
library(tidyverse)
library(ggplot2)
ggplot(df, aes(x = LungCap)) +
geom_boxplot() +
facet_wrap(~ Gender)
ggplot(df, aes(x = LungCap)) +
geom_histogram() +
facet_wrap(~ Gender)
ggplot(df, aes(x = LungCap)) +
geom_boxplot() +
facet_wrap(~ Gender)
ggplot(df, aes(x = LungCap)) +
geom_histogram() +
facet_wrap(~ Gender, nrow = 1)
ggplot(df, aes(x = LungCap)) +
geom_boxplot() +
facet_wrap(~ Gender, nrow = 1)
t_test_result <- t.test(LungCap ~ Smoke, data = df)
t_test_result
summarise(filter(df, Smoke = 'Yes'), avg = mean(LungCap))
summarise(filter(df, Smoke = 'yes'), avg = mean(LungCap))
summarise(filter(df, Smoke == 'yes'), avg = mean(LungCap))
summarise(filter(df, Smoke == 'no'), avg = mean(LungCap))
typeof(df$Age)
df = mutate(df, AgeCat = case_when(
Age <= 13 ~ '<= 13',
Age == 14 ~ '14 to 15',
Age == 15 ~ '14 to 15',
Age == 16 ~ '16 to 17',
Age == 17 ~ '16 to 17',
Age >= 18 ~ '>= 18'
))
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat = '<= 13'))
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat == '<= 13'))
t_test_result
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat == '<= 13'))
t_test_result
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat == '14 to 15'))
t_test_result
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat == '16 to 17'))
t_test_result
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat == '>= 18'))
t_test_result
t_test_result <- t.test(LungCap ~ Smoke, data = filter(df, AgeCat == '>= 18'))
t_test_result
ggplot(df, aes(x = LungCap)) +
geom_boxplot() +
facet_grid(AgeCat ~ Gender)
ggplot(df, aes(x = LungCap)) +
geom_boxplot() +
facet_grid(Gender ~ AgeCat)
