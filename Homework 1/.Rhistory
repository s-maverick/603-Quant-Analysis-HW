expected_value
# Calculate total number of inmates
total_inmates <- sum(data$Frequency)
# Calculate the probabilities
data$Probability <- data$Frequency / total_inmates
# Calculate the expected value (E(X))
expected_value <- sum(data$X * data$Probability)
# Calculate the variance
variance <- sum(data$Probability * (data$X - expected_value)^2)
# Calculate the standard deviation
std_deviation <- sqrt(variance)
# Print results
variance
std_deviation
